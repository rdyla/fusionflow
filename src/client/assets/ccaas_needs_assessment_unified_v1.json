  "requirementGeneration": {
    "enabled": true,
    "statementTemplates": [
      {
        "id": "channel_requirement",
        "condition": "channels_required_phase_1.length > 0",
        "category": "channels",
        "priority": "must",
        "statementTemplate": "The solution must support the following channels in phase 1: {{channels_required_phase_1}}."
      },
      {
        "id": "routing_requirement",
        "condition": "routing_capabilities_required.length > 0",
        "category": "routing",
        "priority": "must",
        "statementTemplate": "The solution must support the following routing capabilities: {{routing_capabilities_required}}."
      },
      {
        "id": "ivr_requirement",
        "condition": "ivr_or_self_service_required == 'yes_phase_1'",
        "category": "ivr",
        "priority": "must",
        "statementTemplate": "IVR and/or self-service capabilities are required in phase 1."
      },
      {
        "id": "crm_requirement",
        "condition": "crm_integration_required_phase_1 == 'yes'",
        "category": "integration",
        "priority": "must",
        "statementTemplate": "CRM integration is required in phase 1."
      },
      {
        "id": "reporting_requirement",
        "condition": "reporting_levels_required.length > 0",
        "category": "reporting",
        "priority": "must",
        "statementTemplate": "The solution must support the following reporting capabilities: {{reporting_levels_required}}."
      },
      {
        "id": "wfm_requirement",
        "condition": "wfm_required == 'yes_phase_1'",
        "category": "wfm",
        "priority": "must",
        "statementTemplate": "WFM capabilities are required in phase 1, including: {{wfm_capabilities_required}}."
      },
      {
        "id": "qm_requirement",
        "condition": "qm_required == 'yes_phase_1'",
        "category": "qm",
        "priority": "must",
        "statementTemplate": "QM capabilities are required in phase 1, including: {{qm_capabilities_required}}."
      },
      {
        "id": "security_requirement",
        "condition": "security_review_required == 'yes'",
        "category": "security",
        "priority": "must",
        "statementTemplate": "Customer security and/or procurement review is a required dependency before purchase and implementation."
      },
      {
        "id": "customer_prerequisite_requirement",
        "condition": "customer_prerequisites_before_design.length > 0",
        "category": "customer_prerequisite",
        "priority": "must",
        "statementTemplate": "Before solution design proceeds, the customer must provide the following prerequisite inputs: {{customer_prerequisites_before_design}}."
      }
    ]
  },

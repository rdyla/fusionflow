{
  "id": "ccaas_needs_assessment_unified_v1",
  "name": "CCaaS Needs Assessment",
  "version": "2.0.0",
  "description": "Pre-solution needs assessment for contact center and omnichannel solutions used to define scope, routing, integrations, workforce, quality, security, and migration requirements prior to design and quoting.",
  "appliesTo": [
    "ccaas"
  ],
  "estimatedCompletionMinutes": 12,
  "solutionScope": {
    "category": "contact_center",
    "supportedPlatforms": [
      "zoom_contact_center",
      "ringcx",
      "genesys",
      "nice_incontact",
      "five9",
      "vonage_contact_center",
      "dialpad_contact_center",
      "other_ccaas_platform"
    ],
    "optionalModules": [
      "omnichannel",
      "wfm",
      "qm",
      "ai_virtual_agent",
      "outbound"
    ]
  },
  "sections": [
    {
      "id": "project_context",
      "title": "Project Context",
      "sectionCategory": "projectContext",
      "scored": false,
      "fields": [
        {
          "id": "deployment_type",
          "type": "single_select",
          "label": "What type of project is this?",
          "required": true,
          "options": [
            { "value": "new_deployment",       "label": "New deployment"                  },
            { "value": "migration",            "label": "Migration / replacement"         },
            { "value": "expansion",            "label": "Expansion of current environment"},
            { "value": "optimization_redesign","label": "Optimization / redesign"         }
          ]
        },
        {
          "id": "current_platform",
          "type": "text",
          "label": "Current contact center platform (if applicable)",
          "required": false,
          "showIf": {
            "field": "deployment_type",
            "operator": "containsAny",
            "value": ["migration", "expansion", "optimization_redesign"]
          }
        },
        {
          "id": "phase_1_scope_summary",
          "type": "textarea",
          "label": "Describe phase 1 scope",
          "required": true
        },
        {
          "id": "future_phase_scope_summary",
          "type": "textarea",
          "label": "Describe future-phase scope (if known)",
          "required": false
        },
        {
          "id": "target_go_live_date",
          "type": "date",
          "label": "Target go-live date",
          "required": false
        },
        {
          "id": "program_owner_function",
          "type": "single_select",
          "label": "Which team is driving this project?",
          "required": true,
          "options": [
            { "value": "it",                    "label": "IT / Technology"          },
            { "value": "contact_center_ops",    "label": "Contact Center Operations"},
            { "value": "executive_initiative",  "label": "Executive initiative"     },
            { "value": "vendor_driven",         "label": "Vendor-driven / renewal"  },
            { "value": "other",                 "label": "Other"                    }
          ]
        }
      ]
    },
    {
      "id": "business_objectives",
      "title": "Business Objectives & Success Metrics",
      "sectionCategory": "businessObjectives",
      "scored": true,
      "fields": [
        {
          "id": "business_goals",
          "type": "multi_select",
          "label": "What are the top business goals for this solution?",
          "required": true,
          "options": [
            { "value": "reduce_wait_time",          "label": "Reduce wait time / queue time"       },
            { "value": "improve_sla",               "label": "Improve SLA / service level"         },
            { "value": "improve_csat",              "label": "Improve CSAT / customer experience"  },
            { "value": "reduce_abandonment",        "label": "Reduce abandonment rate"             },
            { "value": "improve_agent_productivity","label": "Improve agent productivity"          },
            { "value": "reduce_cost_to_serve",      "label": "Reduce cost to serve"                },
            { "value": "expand_digital_channels",   "label": "Expand digital / omnichannel support"},
            { "value": "improve_reporting_visibility","label": "Improve reporting / supervisor visibility"},
            { "value": "improve_wfm",               "label": "Improve workforce management"        },
            { "value": "improve_qm",                "label": "Improve quality management / coaching"}
          ],
          "scoring": {
            "method": "count_band",
            "scoreMap": { "0": 1, "1": 2, "2_3": 3, "4_5": 4, "6_plus": 5 }
          }
        },
        {
          "id": "current_problems_to_solve",
          "type": "textarea",
          "label": "What problems is the customer trying to solve today?",
          "required": true
        },
        {
          "id": "success_90_days",
          "type": "textarea",
          "label": "What does success look like 90 days after go-live?",
          "required": true
        },
        {
          "id": "success_6_12_months",
          "type": "textarea",
          "label": "What does success look like after 6-12 months?",
          "required": true
        },
        {
          "id": "target_kpis",
          "type": "multi_select",
          "label": "Which KPIs does the customer expect to improve?",
          "required": false,
          "options": [
            { "value": "asa",              "label": "ASA"                  },
            { "value": "sla",              "label": "Service level"        },
            { "value": "aht",              "label": "AHT"                  },
            { "value": "csat",             "label": "CSAT"                 },
            { "value": "fcr",              "label": "First contact resolution"},
            { "value": "occupancy",        "label": "Occupancy"            },
            { "value": "adherence",        "label": "Adherence"            },
            { "value": "abandonment_rate", "label": "Abandonment rate"     },
            { "value": "cost_per_contact", "label": "Cost per contact"     },
            { "value": "agent_utilization","label": "Agent utilization"    }
          ]
        }
      ]
    },
    {
      "id": "scope_and_channels",
      "title": "Scope, Agents & Channel Requirements",
      "sectionCategory": "scopeChannels",
      "scored": true,
      "fields": [
        {
          "id": "sites_or_business_units_in_scope",
          "type": "textarea",
          "label": "Which sites, business units, or geographies are in scope?",
          "required": true
        },
        {
          "id": "agent_count_band",
          "type": "single_select",
          "label": "Approximate number of agents in scope",
          "required": true,
          "options": [
            { "value": "1_25",    "label": "1-25",   "score": 1 },
            { "value": "26_100",  "label": "26-100", "score": 2 },
            { "value": "101_250", "label": "101-250","score": 3 },
            { "value": "251_500", "label": "251-500","score": 4 },
            { "value": "500_plus","label": "500+",   "score": 5 }
          ]
        },
        {
          "id": "supervisor_count_band",
          "type": "single_select",
          "label": "Approximate number of supervisors in scope",
          "required": false,
          "options": [
            { "value": "1_5",    "label": "1-5",  "score": 1 },
            { "value": "6_20",   "label": "6-20", "score": 2 },
            { "value": "21_50",  "label": "21-50","score": 3 },
            { "value": "51_plus","label": "51+",  "score": 4 }
          ]
        },
        {
          "id": "channels_required_phase_1",
          "type": "multi_select",
          "label": "Which channels are required in phase 1?",
          "required": true,
          "options": [
            { "value": "voice",  "label": "Voice"                   },
            { "value": "chat",   "label": "Chat / web chat"         },
            { "value": "sms",    "label": "SMS"                     },
            { "value": "email",  "label": "Email"                   },
            { "value": "social", "label": "Social / messaging apps" },
            { "value": "video",  "label": "Video"                   }
          ]
        },
        {
          "id": "channels_future_phase",
          "type": "multi_select",
          "label": "Which channels are planned for future phases?",
          "required": false,
          "options": [
            { "value": "voice",  "label": "Voice"                   },
            { "value": "chat",   "label": "Chat / web chat"         },
            { "value": "sms",    "label": "SMS"                     },
            { "value": "email",  "label": "Email"                   },
            { "value": "social", "label": "Social / messaging apps" },
            { "value": "video",  "label": "Video"                   }
          ]
        }
      ]
    },
    {
      "id": "routing_and_flow_design",
      "title": "Routing, IVR & Flow Design",
      "sectionCategory": "routingFlow",
      "scored": true,
      "fields": [
        {
          "id": "queue_and_skill_requirements",
          "type": "textarea",
          "label": "Describe queue structures, skills, and routing groups required",
          "required": true
        },
        {
          "id": "routing_capabilities_required",
          "type": "multi_select",
          "label": "Which routing capabilities are required?",
          "required": true,
          "options": [
            { "value": "skill_based_routing",              "label": "Skill-based routing"               },
            { "value": "language_based_routing",           "label": "Language-based routing"            },
            { "value": "priority_vip_routing",             "label": "Priority / VIP routing"            },
            { "value": "overflow_routing",                 "label": "Overflow / backup routing"         },
            { "value": "business_hours_routing",           "label": "Business hours / holiday routing"  },
            { "value": "callback",                         "label": "Callback / queue callback"         },
            { "value": "last_agent_or_relationship_routing","label": "Last agent / relationship routing" },
            { "value": "omnichannel_routing",              "label": "Unified omnichannel routing"       }
          ]
        },
        {
          "id": "ivr_or_self_service_required",
          "type": "single_select",
          "label": "Is IVR or self-service required?",
          "required": true,
          "options": [
            { "value": "yes_phase_1",    "label": "Yes, in phase 1",  "score": 5 },
            { "value": "yes_future_phase","label": "Yes, future phase","score": 3 },
            { "value": "no",             "label": "No",               "score": 1 }
          ]
        },
        {
          "id": "ivr_requirements",
          "type": "textarea",
          "label": "Describe IVR, menu, or self-service requirements",
          "required": false,
          "showIf": {
            "field": "ivr_or_self_service_required",
            "operator": "notEquals",
            "value": "no"
          }
        },
        {
          "id": "transfer_and_escalation_requirements",
          "type": "textarea",
          "label": "Describe transfer, escalation, and fallback requirements",
          "required": false
        },
        {
          "id": "business_hours_holiday_logic",
          "type": "textarea",
          "label": "Describe business hours, holiday, and after-hours logic",
          "required": false
        }
      ]
    },
    {
      "id": "agent_supervisor_experience",
      "title": "Agent & Supervisor Experience",
      "sectionCategory": "agentSupervisorExperience",
      "scored": true,
      "fields": [
        {
          "id": "agent_features_required",
          "type": "multi_select",
          "label": "Which agent capabilities are required?",
          "required": true,
          "options": [
            { "value": "screen_pop",             "label": "Screen pop / contextual view"  },
            { "value": "knowledge_access",        "label": "Knowledge access"              },
            { "value": "disposition_codes",       "label": "Disposition codes"             },
            { "value": "after_call_work",         "label": "After-call work controls"      },
            { "value": "internal_consult_transfer","label": "Consult / transfer"           },
            { "value": "blended_work",            "label": "Blended multichannel work"     },
            { "value": "agent_notes",             "label": "Agent notes / wrap-up notes"   }
          ]
        },
        {
          "id": "supervisor_capabilities_required",
          "type": "multi_select",
          "label": "Which supervisor capabilities are required?",
          "required": true,
          "options": [
            { "value": "live_dashboards",      "label": "Live dashboards"          },
            { "value": "real_time_monitoring", "label": "Real-time monitoring"     },
            { "value": "whisper",              "label": "Whisper"                  },
            { "value": "barge",                "label": "Barge"                    },
            { "value": "intercept",            "label": "Intercept / takeover"     },
            { "value": "alerting",             "label": "Operational alerts"       },
            { "value": "queue_monitoring",     "label": "Queue monitoring"         },
            { "value": "agent_state_monitoring","label": "Agent state monitoring"  }
          ]
        }
      ]
    },
    {
      "id": "reporting_analytics",
      "title": "Reporting & Analytics",
      "sectionCategory": "reportingAnalytics",
      "scored": true,
      "fields": [
        {
          "id": "reporting_levels_required",
          "type": "multi_select",
          "label": "What reporting levels are required?",
          "required": true,
          "options": [
            { "value": "real_time_operational","label": "Real-time operational dashboards"},
            { "value": "historical_reporting", "label": "Historical reporting"            },
            { "value": "supervisor_reporting", "label": "Supervisor reporting"            },
            { "value": "executive_reporting",  "label": "Executive reporting"             },
            { "value": "scheduled_reports",    "label": "Scheduled reports"              },
            { "value": "raw_data_export",      "label": "Raw data export / BI feed"      }
          ]
        },
        {
          "id": "custom_dashboards_required",
          "type": "single_select",
          "label": "Are custom dashboards required?",
          "required": true,
          "options": [
            { "value": "yes_phase_1",    "label": "Yes, in phase 1",  "score": 5 },
            { "value": "yes_future_phase","label": "Yes, future phase","score": 3 },
            { "value": "no",             "label": "No",               "score": 1 }
          ]
        },
        {
          "id": "bi_or_data_warehouse_integration_required",
          "type": "single_select",
          "label": "Is BI or data warehouse integration required?",
          "required": true,
          "options": [
            { "value": "yes_phase_1",    "label": "Yes, in phase 1",  "score": 5 },
            { "value": "yes_future_phase","label": "Yes, future phase","score": 3 },
            { "value": "no",             "label": "No",               "score": 1 }
          ]
        }
      ]
    },
    {
      "id": "integrations",
      "title": "Integrations & System Dependencies",
      "sectionCategory": "integrations",
      "scored": true,
      "fields": [
        {
          "id": "crm_in_use",
          "type": "single_select",
          "label": "Which CRM is in use?",
          "required": true,
          "options": [
            { "value": "salesforce",  "label": "Salesforce",  "score": 5 },
            { "value": "dynamics",    "label": "Dynamics",    "score": 4 },
            { "value": "hubspot",     "label": "HubSpot",     "score": 4 },
            { "value": "zendesk",     "label": "Zendesk",     "score": 3 },
            { "value": "service_now", "label": "ServiceNow",  "score": 3 },
            { "value": "other",       "label": "Other",       "score": 2 },
            { "value": "none",        "label": "None",        "score": 1 }
          ]
        },
        {
          "id": "crm_integration_required_phase_1",
          "type": "single_select",
          "label": "Is CRM integration required in phase 1?",
          "required": true,
          "options": [
            { "value": "yes",          "label": "Yes",         "score": 5 },
            { "value": "future_phase", "label": "Future phase","score": 3 },
            { "value": "no",           "label": "No",          "score": 1 }
          ]
        },
        {
          "id": "other_integrations_required",
          "type": "multi_select",
          "label": "What other integrations are required?",
          "required": false,
          "options": [
            { "value": "ticketing",     "label": "Ticketing system"         },
            { "value": "knowledge_base","label": "Knowledge base"           },
            { "value": "identity_sso",  "label": "Identity / SSO"           },
            { "value": "wfm",           "label": "WFM"                      },
            { "value": "qm",            "label": "QM"                       },
            { "value": "bi_warehouse",  "label": "BI / warehouse"           },
            { "value": "payment_system","label": "Payment / PCI workflow"   },
            { "value": "erp_backoffice","label": "ERP / back-office system" },
            { "value": "custom_api",    "label": "Custom API / middleware"  }
          ]
        },
        {
          "id": "sandbox_testing_required",
          "type": "single_select",
          "label": "Is sandbox / test environment validation required?",
          "required": true,
          "options": [
            { "value": "yes",  "label": "Yes",  "score": 5 },
            { "value": "maybe","label": "Maybe","score": 3 },
            { "value": "no",   "label": "No",   "score": 1 }
          ]
        }
      ]
    },
    {
      "id": "wfm_qm_requirements",
      "title": "Workforce & Quality Management",
      "sectionCategory": "wfmQm",
      "scored": true,
      "fields": [
        {
          "id": "wfm_required",
          "type": "single_select",
          "label": "Is WFM required?",
          "required": true,
          "options": [
            { "value": "yes_phase_1",    "label": "Yes, in phase 1",  "score": 5 },
            { "value": "yes_future_phase","label": "Yes, future phase","score": 3 },
            { "value": "no",             "label": "No",               "score": 1 }
          ]
        },
        {
          "id": "wfm_capabilities_required",
          "type": "multi_select",
          "label": "Which WFM capabilities are required?",
          "required": false,
          "showIf": {
            "field": "wfm_required",
            "operator": "notEquals",
            "value": "no"
          },
          "options": [
            { "value": "forecasting",          "label": "Forecasting"                   },
            { "value": "scheduling",           "label": "Scheduling"                    },
            { "value": "intraday_management",  "label": "Intraday management"           },
            { "value": "adherence_tracking",   "label": "Adherence tracking"            },
            { "value": "shrinkage_management", "label": "Shrinkage management"          },
            { "value": "pto_workflows",        "label": "PTO / exception workflows"     },
            { "value": "multi_skill_planning", "label": "Multi-skill planning"          },
            { "value": "approval_workflows",   "label": "Supervisor approval workflows" }
          ]
        },
        {
          "id": "qm_required",
          "type": "single_select",
          "label": "Is QM required?",
          "required": true,
          "options": [
            { "value": "yes_phase_1",    "label": "Yes, in phase 1",  "score": 5 },
            { "value": "yes_future_phase","label": "Yes, future phase","score": 3 },
            { "value": "no",             "label": "No",               "score": 1 }
          ]
        },
        {
          "id": "qm_capabilities_required",
          "type": "multi_select",
          "label": "Which QM capabilities are required?",
          "required": false,
          "showIf": {
            "field": "qm_required",
            "operator": "notEquals",
            "value": "no"
          },
          "options": [
            { "value": "evaluation_scorecards","label": "Evaluation scorecards"          },
            { "value": "calibration",          "label": "Calibration workflows"          },
            { "value": "coaching",             "label": "Coaching workflows"             },
            { "value": "acknowledgement",      "label": "Agent acknowledgement"          },
            { "value": "dispute_process",      "label": "Dispute / appeal process"       },
            { "value": "sampling",             "label": "Call / interaction sampling"    },
            { "value": "auto_evaluation",      "label": "Automated evaluation / AI assist"}
          ]
        }
      ]
    },
    {
      "id": "security_compliance",
      "title": "Security, Compliance & Governance",
      "sectionCategory": "securityCompliance",
      "scored": true,
      "fields": [
        {
          "id": "recording_requirements",
          "type": "single_select",
          "label": "Are call / interaction recording requirements defined?",
          "required": true,
          "options": [
            { "value": "yes_defined",        "label": "Yes, defined",                "score": 5 },
            { "value": "partial",            "label": "Partial / needs clarification","score": 3 },
            { "value": "no",                 "label": "No",                          "score": 1 }
          ]
        },
        {
          "id": "compliance_requirements",
          "type": "multi_select",
          "label": "Which compliance requirements are relevant?",
          "required": false,
          "options": [
            { "value": "pci",                 "label": "PCI"                          },
            { "value": "hipaa",               "label": "HIPAA"                        },
            { "value": "pii",                 "label": "PII"                          },
            { "value": "gdpr",                "label": "GDPR / regional privacy"      },
            { "value": "financial_regulated", "label": "Financial services regulation"},
            { "value": "none_identified",     "label": "None identified"              }
          ]
        },
        {
          "id": "retention_requirements",
          "type": "single_select",
          "label": "Are retention requirements defined?",
          "required": true,
          "options": [
            { "value": "yes_defined",    "label": "Yes, defined",            "score": 5 },
            { "value": "yes_not_defined","label": "Yes, but not yet defined","score": 3 },
            { "value": "no",             "label": "No / none known",         "score": 1 }
          ]
        },
        {
          "id": "redaction_or_pause_resume_required",
          "type": "single_select",
          "label": "Are redaction, masking, or pause/resume controls required?",
          "required": true,
          "options": [
            { "value": "yes",  "label": "Yes",  "score": 5 },
            { "value": "maybe","label": "Maybe","score": 3 },
            { "value": "no",   "label": "No",   "score": 1 }
          ]
        },
        {
          "id": "rbac_required",
          "type": "single_select",
          "label": "Are role-based access controls required?",
          "required": true,
          "options": [
            { "value": "yes",    "label": "Yes",    "score": 5 },
            { "value": "partial","label": "Partial","score": 3 },
            { "value": "no",     "label": "No",     "score": 1 }
          ]
        },
        {
          "id": "security_review_required",
          "type": "single_select",
          "label": "Is security or procurement review required before purchase?",
          "required": true,
          "options": [
            { "value": "yes",    "label": "Yes",    "score": 5 },
            { "value": "unknown","label": "Unknown","score": 2 },
            { "value": "no",     "label": "No",     "score": 1 }
          ]
        }
      ]
    },
    {
      "id": "migration_and_cutover",
      "title": "Migration, Dependencies & Customer Responsibilities",
      "sectionCategory": "migrationDependencies",
      "scored": true,
      "fields": [
        {
          "id": "migration_required",
          "type": "single_select",
          "label": "Is migration from an existing platform required?",
          "required": true,
          "options": [
            { "value": "yes",    "label": "Yes",             "score": 5 },
            { "value": "partial","label": "Partial / phased","score": 3 },
            { "value": "no",     "label": "No",              "score": 1 }
          ]
        },
        {
          "id": "migration_scope_summary",
          "type": "textarea",
          "label": "Describe what must be migrated",
          "required": false,
          "showIf": {
            "field": "migration_required",
            "operator": "notEquals",
            "value": "no"
          }
        },
        {
          "id": "carrier_or_number_dependencies",
          "type": "textarea",
          "label": "Describe telephony, carrier, or number porting dependencies",
          "required": false
        },
        {
          "id": "customer_prerequisites_before_design",
          "type": "multi_select",
          "label": "What must the customer provide before design can proceed?",
          "required": true,
          "options": [
            { "value": "current_call_flows",       "label": "Current call flows / IVR maps"        },
            { "value": "queue_and_skill_definitions","label": "Queue / skill definitions"           },
            { "value": "business_hours_holidays",  "label": "Business hours / holidays"            },
            { "value": "reporting_requirements",   "label": "Reporting requirements"               },
            { "value": "integration_contacts",     "label": "Integration owners / contacts"        },
            { "value": "crm_access",               "label": "CRM / platform access for discovery"  },
            { "value": "security_requirements",    "label": "Security / compliance requirements"   },
            { "value": "wfm_requirements",         "label": "WFM requirements / process inputs"    },
            { "value": "qm_scorecards",            "label": "QM scorecards / evaluation criteria"  }
          ]
        },
        {
          "id": "signoff_roles",
          "type": "multi_select",
          "label": "Who must approve the Statement of Requirements before design / quote?",
          "required": true,
          "options": [

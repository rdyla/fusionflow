    "statusBands": [
      { "label": "ready",               "min": 80, "max": 100 },
      { "label": "conditionally_ready", "min": 60, "max": 79  },
      { "label": "not_ready",           "min": 0,  "max": 59  }
    ]
  },
  "decisionModel": {
    "enabled": true,
    "recommendations": [
      {
        "condition": "overallReadiness >= 80",
        "status": "ready",
        "recommendedAction": "Proceed to solution design and quote once the Statement of Requirements is approved."
      },
      {
        "condition": "overallReadiness >= 60 && overallReadiness < 80",
        "status": "conditionally_ready",
        "recommendedAction": "Proceed only after dependencies, scope gaps, or unresolved requirements are addressed."
      },
      {
        "condition": "overallReadiness < 60",
        "status": "not_ready",
        "recommendedAction": "Do not proceed to design / quote until discovery gaps and prerequisites are resolved."
      }
    ]
  }
